# --- LLM (OpenAI SDK-compatible) ---
# OpenAI를 그대로 쓸 경우 OPENAI_BASE_URL은 비워두세요.
# 무료 대안:
#   Google Gemini: https://generativelanguage.googleapis.com/v1beta/openai/  (모델 예: gemini-2.5-flash)
#   Groq:          https://api.groq.com/openai/v1                            (모델 예: llama-3.3-70b-versatile)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# --- NCBI / PubMed (Bio Entrez E-utilities) ---
NCBI_API_KEY=
ENTREZ_EMAIL=

# --- Supabase (Service Role - 서버 전용, 절대 프론트엔드에 노출 금지) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Server ---
PORT=4000
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
