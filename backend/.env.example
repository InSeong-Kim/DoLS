# --- LLM (OpenAI SDK-compatible) ---
# 이 값들은 순수 한국어 문장을 생성하는 곳(용어 설명, 저장 논문 Q&A)에 쓰입니다.
# OpenAI를 그대로 쓸 경우 OPENAI_BASE_URL은 비워두세요.
# 무료 대안:
#   Google Gemini: https://generativelanguage.googleapis.com/v1beta/openai/  (모델 예: gemini-2.5-flash)
#   Groq:          https://api.groq.com/openai/v1                            (모델 예: llama-3.3-70b-versatile)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# JSON_OPENAI_* 는 칩+문단이 섞인 JSON 요약/분석(검색 요약, 논문별 AI 분석)에만 쓰이는
# "두 번째" provider입니다. 비워두면 위 OPENAI_* 를 그대로 재사용합니다(단일 provider).
# 채워두면 두 provider에 부하가 나뉘어서 한쪽 무료 한도(429)에 덜 걸립니다.
JSON_OPENAI_API_KEY=
JSON_OPENAI_BASE_URL=
JSON_OPENAI_MODEL=

# 무료 티어 요청 제한(429) 방지용 속도제한(분당). 쓰는 제공사의 분당 한도보다 낮게 잡으세요.
# 두 provider 각각에 독립적으로 적용됩니다.
LLM_REQUESTS_PER_MINUTE=10

# --- NCBI / PubMed (Bio Entrez E-utilities) ---
NCBI_API_KEY=
ENTREZ_EMAIL=

# --- Supabase (Service Role - 서버 전용, 절대 프론트엔드에 노출 금지) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Server ---
PORT=4000
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
